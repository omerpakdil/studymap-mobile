{
  "expo": {
    "name": "StudyMap",
    "slug": "studymap-pro",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "studymapmobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "metro": {
      "resolver": {
        "assetExts": [
          "bin",
          "txt",
          "jpg",
          "png",
          "json",
          "gif",
          "webp",
          "svg",
          "html",
          "mp3",
          "wav"
        ]
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studymap.mobile",
      "buildNumber": "35",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["audio"],
        "CFBundleLocalizations": [
          "en",
          "tr",
          "de",
          "fr",
          "ar",
          "ja",
          "ko",
          "pt-BR",
          "zh-Hans",
          "id",
          "hi"
        ]
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A1513"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#0F9D8C",
          "mode": "production"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "84e831a9-977e-48cf-b479-41d49550fdd5"
      }
    },
    "android": {
      "package": "com.studymap.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A1513"
      }
    }
  }
}
