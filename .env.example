# StudyMap Mobile App - Environment Variables
# Copy this file to .env and replace the placeholder values with your actual API keys

# RevenueCat API Key
# Get it from: https://app.revenuecat.com/ → Project Settings → API Keys
EXPO_PUBLIC_REVENUECAT_API_KEY=your-revenuecat-api-key-here

# App Configuration
EXPO_PUBLIC_APP_NAME=StudyMap
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/id6748285218
EXPO_PUBLIC_ANALYTICS_PROVIDER=console
EXPO_PUBLIC_PAYWALL_VARIANT=default_v1

# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Get your API keys from the URLs above
# 3. Replace the placeholder values in .env
# 4. Restart your development server
